    "pos.tender"
  ],
  "locales": [
    "en-US"
  ],
  "entries": [
    {
      "type": "payment",
      "key": "qrpay",
      "label": "QR Pay",
      "sort_order": 1,
      "trigger_event": "payment.qrpay.requested"
    }
  ]
}
